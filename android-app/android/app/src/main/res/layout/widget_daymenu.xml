<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E8743B"
            android:textSize="30sp"
            android:textStyle="bold"
            android:text="— h" />

        <TextView
            android:id="@+id/widget_sub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="#ECEFF4"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Otwórz Day Menu, aby wczytać dane" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#9AA3B2"
        android:textSize="11sp"
        android:text="Produktywność — ostatnie 7 dni" />

    <ImageView
        android:id="@+id/widget_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:scaleType="fitCenter"
        android:contentDescription="Wykres produktywności" />
</LinearLayout>
